# Copy this to .env.docker and fill in your values.
# .env.docker is git-ignored and used by docker-compose.

DATABASE_URL=postgres://storepulse:storepulse@db:5432/storepulse

# Mapbox (client-side map rendering)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# Google Maps (server-side Places scraping)
GOOGLE_MAPS_API_KEY=AIzaSy...
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# Admin gate — set to your email
NEXT_PUBLIC_ADMIN_EMAIL=you@example.com

# Admin secret — used to authenticate admin API calls
# Generate: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-long-random-string
NEXT_PUBLIC_ADMIN_SECRET=change-me-to-a-long-random-string

# LTA DataMall API key (free — https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html)
LTA_API_KEY=

# Optional: for Cloud Run / Cloud SQL in production
# DATABASE_URL=postgres://user:pass@/storepulse?host=/cloudsql/PROJECT:REGION:INSTANCE
